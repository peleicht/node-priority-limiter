{
	"compilerOptions": {
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "es2022",
		"module": "NodeNext",
		"allowJs": true,
		"resolveJsonModule": true,
		"moduleDetection": "force",
		"isolatedModules": true,
		"declaration": true,
		"strict": true,
		"allowSyntheticDefaultImports": true,
		"outDir": "dist",
		"types": ["node"]
	},
	"include": ["index.ts"],
	"exclude": ["node_modules, dist"]
}
